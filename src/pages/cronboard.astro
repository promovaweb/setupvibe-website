---
import Layout from '../layouts/main.astro';
import { CronboardContent } from '@/components/CronboardContent';
import { PageHeader } from '@/components/PageHeader';
import { Calendar } from 'lucide-react';
---

<Layout 
  title="Cronboard & Crontab: Agendamento Visual de Tarefas | SetupVibe"
  description="Gerencie seus cronjobs de forma visual com Cronboard. Automatize backups, scripts de IA e tarefas recorrentes no Linux com facilidade."
>
  <PageHeader
    client:load
    title="Controle visual e"
    gradientTitle="automação total"
    subtitle="Chega de se perder no crontab -e. Gerencie suas tarefas recorrentes e scripts de backup de forma visual, simples e organizada."
    badge={{ icon: "📅", text: "Automação" }}
  />

  <main>
    <CronboardContent client:load />
  </main>
</Layout>
