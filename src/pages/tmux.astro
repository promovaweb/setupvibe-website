---
import Layout from '../layouts/main.astro';
import { PageHeader } from '@/components/PageHeader';
import { TmuxContent } from '@/components/TmuxContent';
import { PromovawebCTA } from '@/components/PromovawebCTA';
---

<Layout 
	title="tmux no SetupVibe: Guia de Multiplexação e Produtividade"
	description="Aprenda a dominar o tmux com configurações otimizadas pelo SetupVibe. Gerencie múltiplas sessões e painéis como um profissional do terminal. Melhore seu workflow!"
>
	<PageHeader 
		client:load
		title="Sessões indestrutíveis" 
		gradientTitle="e persistentes"
		subtitle="Mantenha seus projetos rodando mesmo se a conexão cair ou se você fechar o terminal. Divida telas, alterne contextos e recupere o trabalho de onde parou."
		badge={{ icon: "🔗", text: "Resiliência" }}
	/>

	<TmuxContent client:load />
    <PromovawebCTA client:load />
</Layout>
