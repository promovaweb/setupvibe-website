---
import Layout from '@/layouts/main.astro';
import { PageHeader } from '@/components/PageHeader';
import { getCollection, render } from 'astro:content';
import { Sparkles, Zap, ChevronLeft, ChevronRight, ExternalLink, Tag, Calendar } from 'lucide-react';
import { withBase } from '@/lib/utils';
import { PromovawebCTA } from '@/components/PromovawebCTA';

export async function getStaticPaths({ paginate }) {
  const changelogEntries = await getCollection('changelog');
  // Ordenar por data decrescente
  const sortedEntries = changelogEntries.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
  
  return paginate(sortedEntries, { pageSize: 5 });
}

const { page } = Astro.props;
const sourceUrl = "https://github.com/promovaweb/setupvibe/blob/main/CHANGELOG.md";

// Renderizar todos os conteúdos no frontmatter para evitar problemas de async no template
const renderedEntries = await Promise.all(page.data.map(async (entry) => {
  const { Content } = await render(entry);
  return { ...entry, Content };
}));

// Helper para formatar data
const formatDate = (date) => {
  return new Intl.DateTimeFormat('pt-BR', {
    day: 'numeric',
    month: 'long',
    year: 'numeric'
  }).format(date);
};
---

<Layout 
	title={`Changelog - Página ${page.currentPage} - SetupVibe`}
	description="Acompanhe todas as novidades, correções de bugs e novas ferramentas adicionadas ao SetupVibe."
>
	<PageHeader 
		client:load
		title="Nosso" 
		gradientTitle="Changelog"
		subtitle="Novas funcionalidades, melhorias e correções. Evoluindo o seu setup diariamente."
		badge={{ icon: "🚀", text: "Latest v0.38.0" }}
	>
		<div class="pt-4">
			<a 
				href={sourceUrl} 
				target="_blank" 
				rel="noopener noreferrer"
				class="inline-flex items-center gap-2 text-sm text-primary hover:underline font-medium"
			>
				<ExternalLink class="h-4 w-4" />
				Ver Changelog Original no GitHub
			</a>
		</div>
	</PageHeader>

	<section class="pb-20 md:pb-32">
		<div class="container mx-auto px-4">
			<div class="max-w-4xl mx-auto">
				{/* Timeline */}
				<div class="relative">
					<div class="absolute left-4 top-0 bottom-0 w-0.5 bg-border hidden md:block" />

					{renderedEntries.map((entry, index) => (
            <div class="relative mb-16 md:pl-12 group/item">
              <div class={`absolute left-0 w-8 h-8 rounded-full border-4 border-background hidden md:flex items-center justify-center transition-colors duration-300 ${index === 0 && page.currentPage === 1 ? 'bg-primary' : 'bg-muted border-border group-hover/item:border-primary/50'}`}>
                {index === 0 && page.currentPage === 1 ? (
                  <Sparkles class="h-4 w-4 text-primary-foreground" />
                ) : (
                  <Zap class="h-4 w-4 text-muted-foreground group-hover/item:text-primary transition-colors" />
                )}
              </div>

              <div class="border rounded-2xl p-6 md:p-8 bg-card hover:shadow-xl hover:shadow-primary/5 transition-all duration-300 relative overflow-hidden group/card">
                {index === 0 && page.currentPage === 1 && (
                  <div class="absolute top-0 right-0 px-4 py-1.5 bg-primary text-primary-foreground text-[10px] font-bold uppercase tracking-[0.1em] rounded-bl-xl shadow-sm">
                    Latest Release
                  </div>
                )}
								
                <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
                  <div class="flex items-center gap-4">
                    <a 
                      href={withBase(`/changelog/${entry.id}`)} 
                      class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-primary/5 text-primary border border-primary/10 hover:bg-primary hover:text-primary-foreground transition-all duration-300 font-mono text-sm font-bold group/version"
                    >
                      <Tag class="w-3.5 h-3.5" />
                      v{entry.data.version}
                    </a>
                    <span class="text-sm text-muted-foreground flex items-center gap-1.5 font-medium">
                      <Calendar class="h-4 w-4 opacity-70" />
                      {formatDate(entry.data.date)}
                    </span>
                  </div>
                </div>

                <h3 class="text-2xl font-bold mb-6 group-hover/card:text-primary transition-colors duration-300">
                  <a href={withBase(`/changelog/${entry.id}`)}>{entry.data.title}</a>
                </h3>

                <div class="prose prose-sm dark:prose-invert max-w-none changelog-content mb-8
                  prose-h3:text-base prose-h3:font-semibold prose-h3:mb-2 prose-h3:mt-4                  
                  prose-ul:list-disc prose-ul:ml-6 prose-ul:mb-4 prose-ul:space-y-1
                  prose-li:marker:text-primary prose-li:text-muted-foreground

                  [&_h3]:flex [&_h3]:items-center [&_h3]:gap-2
                  [&_.changelog-added]:text-green-600 [&_.changelog-added]:dark:text-green-400
                  [&_h3:has(.changelog-added)]:before:content-['✨'] [&_h3:has(.changelog-added)]:before:text-sm
                  
                  [&_.changelog-fixed]:text-red-600 [&_.changelog-fixed]:dark:text-red-400
                  [&_h3:has(.changelog-fixed)]:before:content-['🐛'] [&_h3:has(.changelog-fixed)]:before:text-sm
                  
                  [&_.changelog-changed]:text-blue-600 [&_.changelog-changed]:dark:text-blue-400
                  [&_h3:has(.changelog-changed)]:before:content-['⚡'] [&_h3:has(.changelog-changed)]:before:text-sm
                  
                  [&_.changelog-docs]:text-purple-600 [&_.changelog-docs]:dark:text-purple-400
                  [&_h3:has(.changelog-docs)]:before:content-['📖'] [&_h3:has(.changelog-docs)]:before:text-sm
                ">
                  <entry.Content />
                </div>
                
                <div class="pt-6 border-t border-dashed flex justify-end">
                  <a 
                    href={withBase(`/changelog/${entry.id}`)} 
                    class="inline-flex items-center gap-2 text-sm font-bold text-primary hover:gap-3 transition-all duration-300 py-2 px-4 rounded-lg hover:bg-primary/5 border border-transparent hover:border-primary/10"
                  >
                    Ver detalhes completos <ChevronRight class="h-4 w-4" />
                  </a>
                </div>
              </div>
            </div>
          ))}
				</div>

				{/* Pagination */}
				<div class="flex flex-col items-center gap-4 mt-12">
          <div class="flex items-center gap-2">
            {page.url.prev ? (
              <a href={page.url.prev} class="inline-flex items-center justify-center h-10 w-10 rounded-md border bg-background hover:bg-accent transition-colors">
                <ChevronLeft class="h-4 w-4" />
              </a>
            ) : (
              <div class="inline-flex items-center justify-center h-10 w-10 rounded-md border bg-background opacity-50 cursor-not-allowed">
                <ChevronLeft class="h-4 w-4" />
              </div>
            )}

            <div class="flex items-center gap-1 px-4 text-sm font-medium">
              Página {page.currentPage} de {page.lastPage}
            </div>

            {page.url.next ? (
              <a href={page.url.next} class="inline-flex items-center justify-center h-10 w-10 rounded-md border bg-background hover:bg-accent transition-colors">
                <ChevronRight class="h-4 w-4" />
              </a>
            ) : (
              <div class="inline-flex items-center justify-center h-10 w-10 rounded-md border bg-background opacity-50 cursor-not-allowed">
                <ChevronRight class="h-4 w-4" />
              </div>
            )}
          </div>
          <p class="text-xs text-muted-foreground">
            Mostrando {page.start + 1}-{page.end + 1} de {page.total} versões
          </p>
        </div>
			</div>
		</div>
	</section>
  <PromovawebCTA client:load />
</Layout>
