---
import Layout from '@/layouts/main.astro';
import { getCollection, render } from 'astro:content';
import { Sparkles, Zap, ChevronLeft, ChevronRight, ExternalLink, Plus, Wrench, Bug } from 'lucide-react';
import { withBase } from '@/lib/utils';

export async function getStaticPaths({ paginate }) {
  const changelogEntries = await getCollection('changelog');
  // Ordenar por data decrescente
  const sortedEntries = changelogEntries.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
  
  return paginate(sortedEntries, { pageSize: 5 });
}

const { page } = Astro.props;
const sourceUrl = "https://github.com/promovaweb/setupvibe/blob/main/CHANGELOG.md";

// Renderizar todos os conteúdos no frontmatter para evitar problemas de async no template
const renderedEntries = await Promise.all(page.data.map(async (entry) => {
  const { Content } = await render(entry);
  return { ...entry, Content };
}));

// Helper para formatar data
const formatDate = (date) => {
  return new Intl.DateTimeFormat('pt-BR', {
    day: 'numeric',
    month: 'long',
    year: 'numeric'
  }).format(date);
};
---

<Layout 
	title={`Changelog - Página ${page.currentPage} - SetupVibe`}
	description="Acompanhe todas as novidades, correções de bugs e novas ferramentas adicionadas ao SetupVibe."
>
	<section class="py-20 md:py-32">
		<div class="container mx-auto px-4">
			<div class="max-w-4xl mx-auto">
				{/* Header */}
				<div class="text-center space-y-4 mb-16">
					<h1 class="text-4xl md:text-6xl font-bold">
						<span class="bg-gradient-to-r from-purple-600 to-pink-600 dark:from-purple-400 dark:to-pink-400 bg-clip-text text-transparent">
							Changelog
						</span>
					</h1>
					<p class="text-xl text-muted-foreground max-w-2xl mx-auto">
						Novas funcionalidades, melhorias e correções. Evoluindo o seu setup.
					</p>
					<div class="pt-4">
						<a 
							href={sourceUrl} 
							target="_blank" 
							rel="noopener noreferrer"
							class="inline-flex items-center gap-2 text-sm text-primary hover:underline font-medium"
						>
							<ExternalLink class="h-4 w-4" />
							Ver Changelog Original no GitHub
						</a>
					</div>
				</div>

				{/* Timeline */}
				<div class="relative">
					<div class="absolute left-4 top-0 bottom-0 w-0.5 bg-border hidden md:block" />

					{renderedEntries.map((entry, index) => (
            <div class="relative mb-12 md:pl-12 group">
              <div class={`absolute left-0 w-8 h-8 rounded-full border-4 border-background hidden md:flex items-center justify-center ${index === 0 && page.currentPage === 1 ? 'bg-primary' : 'bg-muted border-border'}`}>
                {index === 0 && page.currentPage === 1 ? (
                  <Sparkles class="h-4 w-4 text-primary-foreground" />
                ) : (
                  <Zap class="h-4 w-4 text-muted-foreground" />
                )}
              </div>

              <div class="border rounded-lg p-6 bg-card hover:shadow-md transition-shadow relative overflow-hidden">
                {index === 0 && page.currentPage === 1 && (
                  <div class="absolute top-0 right-0 px-3 py-1 bg-primary/10 text-primary text-[10px] font-bold uppercase tracking-wider rounded-bl-lg">
                    Latest
                  </div>
                )}
                <div class="flex items-center gap-3 mb-4">
                  <a href={withBase(`/changelog/${entry.id}`)} class="hover:underline">
                    <span class={`px-3 py-1 text-sm font-semibold rounded-full ${index === 0 && page.currentPage === 1 ? 'bg-primary/10 text-primary' : 'bg-muted text-muted-foreground'}`}>
                      v{entry.data.version}
                    </span>
                  </a>
                  <span class="text-sm text-muted-foreground">
                    {formatDate(entry.data.date)}
                  </span>
                </div>

                <h3 class="text-xl font-bold mb-4">{entry.data.title}</h3>

                <div class="prose prose-sm dark:prose-invert max-w-none 
                  prose-h3:text-base prose-h3:font-semibold prose-h3:mb-2 prose-h3:mt-4
                  prose-ul:list-disc prose-ul:ml-6 prose-li:text-muted-foreground
                  [&_h3]:flex [&_h3]:items-center [&_h3]:gap-2
                  [&_.changelog-added]:text-green-600 [&_.changelog-added]:dark:text-green-400
                  [&_.changelog-fixed]:text-red-600 [&_.changelog-fixed]:dark:text-red-400
                  [&_.changelog-changed]:text-blue-600 [&_.changelog-changed]:dark:text-blue-400
                  [&_.changelog-docs]:text-purple-600 [&_.changelog-docs]:dark:text-purple-400
                ">
                  <entry.Content />
                </div>
                
                <div class="mt-6 pt-4 border-t">
                  <a href={withBase(`/changelog/${entry.id}`)} class="text-sm font-medium text-primary hover:underline inline-flex items-center gap-1">
                    Ver página da versão <ChevronRight class="h-4 w-4" />
                  </a>
                </div>
              </div>
            </div>
          ))}
				</div>

				{/* Pagination */}
				<div class="flex flex-col items-center gap-4 mt-12">
          <div class="flex items-center gap-2">
            {page.url.prev ? (
              <a href={page.url.prev} class="inline-flex items-center justify-center h-10 w-10 rounded-md border bg-background hover:bg-accent transition-colors">
                <ChevronLeft class="h-4 w-4" />
              </a>
            ) : (
              <div class="inline-flex items-center justify-center h-10 w-10 rounded-md border bg-background opacity-50 cursor-not-allowed">
                <ChevronLeft class="h-4 w-4" />
              </div>
            )}

            <div class="flex items-center gap-1 px-4 text-sm font-medium">
              Página {page.currentPage} de {page.lastPage}
            </div>

            {page.url.next ? (
              <a href={page.url.next} class="inline-flex items-center justify-center h-10 w-10 rounded-md border bg-background hover:bg-accent transition-colors">
                <ChevronRight class="h-4 w-4" />
              </a>
            ) : (
              <div class="inline-flex items-center justify-center h-10 w-10 rounded-md border bg-background opacity-50 cursor-not-allowed">
                <ChevronRight class="h-4 w-4" />
              </div>
            )}
          </div>
          <p class="text-xs text-muted-foreground">
            Mostrando {page.start + 1}-{page.end + 1} de {page.total} versões
          </p>
        </div>
			</div>
		</div>
	</section>
</Layout>