---
import Layout from '../layouts/main.astro';
import { PageHeader } from '@/components/PageHeader';
import { ToolsContent } from '@/components/ToolsContent';
import { PromovawebCTA } from '@/components/PromovawebCTA';
---

<Layout 
	title="Ferramentas e Stack do SetupVibe: O Guia Completo 2026"
	description="Explore todas as ferramentas, linguagens e utilitários que o SetupVibe configura automaticamente. Potencialize seu ambiente de Vibe Coding. Confira a stack!"
>
	<PageHeader 
		client:load
		title="O arsenal profissional do" 
		gradientTitle="Dev do Futuro"
		subtitle="Mais do que uma coleção de ferramentas, o SetupVibe entrega uma arma de precisão configurada para extrair o máximo de performance de cada linha de código que você escreve."
		badge={{ icon: "⚡", text: "Performance Extrema" }}
	/>

	<ToolsContent client:load />
    <PromovawebCTA client:load />
</Layout>
