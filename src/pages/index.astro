---
import Layout from '../layouts/main.astro';
import { Hero } from '@/components/Hero';
import { Features } from '@/components/Features';
import { CrossPlatformCTA } from '@/components/CrossPlatformCTA';
import { ModulesGrid } from '@/components/ModulesGrid';
import { Testimonials } from '@/components/Testimonials';
import { PromovawebCTA } from '@/components/PromovawebCTA';
import { Pricing } from '@/components/Pricing';
import { FAQ } from '@/components/FAQ';
---

<Layout 
	title="SetupVibe: Seu Ambiente para Vibe Coding pronto em 5 minutos"
	description="Automatize o setup do seu terminal para IA com SetupVibe. Ambiente completo para Vibe Coding com ZSH, Starship e ferramentas de IA em 5 minutos. Instale agora!"
>
  <script type="application/ld+json" is:inline slot="head">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "url": "https://setupvibe.dev",
      "name": "SetupVibe",
      "description": "Seu Ambiente para Vibe Coding pronto em 5 minutos para MacOS, Linux e Windows (WSL).",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "https://setupvibe.dev/?s={search_term_string}",
        "query-input": "required name=search_term_string"
      },
      "keywords": "vibe coding, ai development, terminal setup, zsh starship, claude-code, gemini-cli, automation, debian, ubuntu, wsl, wsl2, macos"
    }
  </script>

	<Hero client:load />
	<Features client:load />
	<CrossPlatformCTA client:load />
	<ModulesGrid client:load />
	<Testimonials client:load />
	<PromovawebCTA client:load />
	<FAQ client:load />
</Layout>
