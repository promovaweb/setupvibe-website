---
import Layout from '../layouts/main.astro';
import { Hero } from '@/components/Hero';
import { Features } from '@/components/Features';
import { ModulesGrid } from '@/components/ModulesGrid';
import { Testimonials } from '@/components/Testimonials';
import { PromovawebCTA } from '@/components/PromovawebCTA';
import { Pricing } from '@/components/Pricing';
import { FAQ } from '@/components/FAQ';
---

<Layout 
	title="SetupVibe - O Seu Ambiente Vibe Coding em 1 Clique"
	description="Não perca tempo configurando o terminal. O SetupVibe prepara sua máquina (Mac e Linux) com as melhores ferramentas para Vibe Coding instantaneamente."
>
  <script type="application/ld+json" is:inline slot="head">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "url": "https://setupvibe.dev",
      "name": "SetupVibe",
      "description": "Ambiente de desenvolvimento 1-click para Vibe Coding com IA.",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "https://setupvibe.dev/?s={search_term_string}",
        "query-input": "required name=search_term_string"
      },
      "keywords": "vibe coding, ai development, terminal setup, zsh starship, claude-code, gemini-cli, automation, marketing automation"
    }
  </script>

	<Hero client:load />
	<Features client:load />
	<ModulesGrid client:load />
	<Testimonials client:load />
	<PromovawebCTA client:load />
	<FAQ client:load />
</Layout>
