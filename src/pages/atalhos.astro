---
import Layout from '../layouts/main.astro';
import { PageHeader } from '@/components/PageHeader';
import { AliasesContent } from '@/components/AliasesContent';
import { PromovawebCTA } from '@/components/PromovawebCTA';
---

<Layout 
	title="Aliases e Atalhos do SetupVibe: Produtividade no Shell"
	description="Domine seu terminal com centenas de aliases e atalhos inteligentes pré-configurados pelo SetupVibe para Git, Docker e mais. Aumente sua velocidade de coding!"
>
	<PageHeader 
		client:load
		title="Digite menos e" 
		gradientTitle="crie muito mais"
		subtitle="O SetupVibe entrega centenas de atalhos inteligentes que eliminam o peso mental de lembrar comandos longos. Foque na lógica, nós cuidamos da sintaxe."
		badge={{ icon: "🚀", text: "Produtividade Real" }}
	/>

	<AliasesContent client:load />
    <PromovawebCTA client:load />
</Layout>
