---
import Layout from '../layouts/main.astro';
import { PageHeader } from '@/components/PageHeader';
import { AliasesContent } from '@/components/AliasesContent';
import { PromovawebCTA } from '@/components/PromovawebCTA';
---

<Layout 
	title="Aliases e Atalhos - SetupVibe"
	description="Explore a lista completa de aliases e atalhos de terminal pré-configurados pelo SetupVibe para Git, Docker, Node.js, PHP, e muito mais."
>
	<PageHeader 
		client:load
		title="Domine seu Terminal" 
		gradientTitle="com Aliases"
		subtitle="O SetupVibe injeta centenas de atalhos inteligentes no seu Shell para que você digite menos e produza muito mais, em qualquer plataforma."
		badge={{ icon: "⌨️", text: "Produtividade Máxima" }}
	/>

	<AliasesContent client:load />
    <PromovawebCTA client:load />
</Layout>
