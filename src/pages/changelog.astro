---
import Layout from '../layouts/main.astro';
import { ExternalLink } from 'lucide-react';
import { ChangelogList } from '@/components/ChangelogList';

const sourceUrl = "https://github.com/promovaweb/setupvibe/blob/main/CHANGELOG.md";
---

<Layout 
	title="Changelog - Novidades e Atualizações do SetupVibe"
	description="Acompanhe todas as novidades, correções de bugs e novas ferramentas adicionadas ao SetupVibe. Sempre iterando para o melhor Vibe Coding."
>
	<section class="py-20 md:py-32">
		<div class="container mx-auto px-4">
			<div class="max-w-4xl mx-auto">
				{/* Header */}
				<div class="text-center space-y-4 mb-16">
					<h1 class="text-4xl md:text-6xl font-bold">
						<span class="bg-gradient-to-r from-purple-600 to-pink-600 dark:from-purple-400 dark:to-pink-400 bg-clip-text text-transparent">
							Changelog
						</span>
					</h1>
					<p class="text-xl text-muted-foreground max-w-2xl mx-auto">
						Novas funcionalidades, melhorias e correções. Evoluindo o seu setup.
					</p>
					<div class="pt-4">
						<a 
							href={sourceUrl} 
							target="_blank" 
							rel="noopener noreferrer"
							class="inline-flex items-center gap-2 text-sm text-primary hover:underline font-medium"
						>
							<ExternalLink class="h-4 w-4" />
							Ver Changelog Original no GitHub
						</a>
					</div>
				</div>

				{/* Paginated List */}
				<ChangelogList client:load />

				{/* Subscribe to Updates */}
				<div class="mt-24 border rounded-lg p-8 bg-gradient-to-br from-purple-500/5 to-pink-500/5 text-center">
					<h3 class="text-2xl font-bold mb-2">Fique por dentro</h3>
					<p class="text-muted-foreground mb-6">
						Receba notificações sobre novos releases e ferramentas.
					</p>
					<div class="flex gap-2 max-w-md mx-auto">
						<input
							type="email"
							placeholder="Seu melhor e-mail"
							class="flex-1 h-10 rounded-md border bg-background px-3 py-2 text-sm"
						/>
						<button class="h-10 px-6 rounded-md bg-primary text-primary-foreground font-medium hover:bg-primary/90 transition-colors">
							Inscrever
						</button>
					</div>
				</div>
			</div>
		</div>
	</section>
</Layout>