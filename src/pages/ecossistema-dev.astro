---
import Layout from '../layouts/main.astro';
import { PageHeader } from '@/components/PageHeader';
import { DevEcosystemContent } from '@/components/DevEcosystemContent';
import { PromovawebCTA } from '@/components/PromovawebCTA';
---

<Layout 
	title="Ecossistema Dev do SetupVibe: Linguagens e Runtimes"
	description="Tenha Go, Rust, Python e Node.js configurados e prontos para produção com o SetupVibe. Esqueça conflitos de versão e foque no código. Prepare sua máquina já!"
>
	<PageHeader 
		client:load
		title="Ecossistema" 
		gradientTitle="Dev Completo"
		subtitle="Sua máquina pronta para qualquer desafio. Instalamos e configuramos as linguagens mais modernas do mercado de forma nativa e sem conflitos."
		badge={{ icon: "🚀", text: "Full-Stack Ready" }}
	/>

	<DevEcosystemContent client:load />
    <PromovawebCTA client:load />
</Layout>
