---
import Layout from '../layouts/main.astro';
import { PageHeader } from '@/components/PageHeader';
import { ModernUnixContent } from '@/components/ModernUnixContent';
import { PromovawebCTA } from '@/components/PromovawebCTA';
---

<Layout 
	title="Modern Unix no SetupVibe: Utilitários Rust Ultra Rápidos"
	description="Substitua comandos clássicos por ferramentas modernas como eza, bat e fd no SetupVibe. Mais velocidade e interface visual rica no seu terminal. Confira agora!"
>
	<PageHeader 
		client:load
		title="Onde a beleza encontra a" 
		gradientTitle="performance bruta"
		subtitle="Esqueça o terminal cinza de 1970. Trazemos o poder do Rust e utilitários modernos que tornam a visualização de arquivos e a navegação uma experiência visual de elite."
		badge={{ icon: "💎", text: "Experiência Visual" }}
	/>

	<ModernUnixContent client:load />
    <PromovawebCTA client:load />
</Layout>
