---
import Layout from '../layouts/main.astro';
import { PageHeader } from '@/components/PageHeader';
import { BatteriesIncludedContent } from '@/components/BatteriesIncludedContent';
import { PromovawebCTA } from '@/components/PromovawebCTA';
---

<Layout 
	title="O que vem no SetupVibe - Ferramentas (Batteries Included)"
	description="Descubra todas as ferramentas inclusas por padrão no SetupVibe: Node, Python rápido (uv), Docker, Portainer, Starship e dezenas de utilitários Modern Unix."
>
	<PageHeader 
		client:load
		title="Tudo o que" 
		gradientTitle="Vem na Caixa"
		subtitle="Uma lista de todos os componentes, linguagens e ferramentas configuradas pelo SetupVibe. Nenhum detalhe oculto. Nenhuma ferramenta em contêiner fechado."
		badge={{ icon: "🔋", text: "Baterias Inclusas v0.38.0" }}
	/>

	<BatteriesIncludedContent client:load />
    <PromovawebCTA client:only="react" />
</Layout>
