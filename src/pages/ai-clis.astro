---
import Layout from '../layouts/main.astro';
import { PageHeader } from '@/components/PageHeader';
import { AiCliContent } from '@/components/AiCliContent';
import { PromovawebCTA } from '@/components/PromovawebCTA';
---

<Layout 
	title="AI CLI Tools no SetupVibe: O Futuro do Terminal com IA"
	description="Explore ferramentas de IA como Claude Code e Gemini CLI integradas nativamente ao SetupVibe. Aumente sua produtividade com IA no terminal. Experimente agora!"
>
	<PageHeader 
		client:load
		title="A inteligência total na ponta" 
		gradientTitle="dos seus dedos"
		subtitle="O terminal não é mais apenas texto; agora é conversa, ação e criação. Tenha Claude, Gemini e Copilot integrados nativamente para escrever, debugar e rodar código em segundos."
		badge={{ icon: "🤖", text: "Vantagem Competitiva" }}
	/>

	<AiCliContent client:load />
    <PromovawebCTA client:load />
</Layout>
