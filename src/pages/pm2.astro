---
import Layout from '../layouts/main.astro';
import { PageHeader } from '@/components/PageHeader';
import { Pm2Content } from '@/components/Pm2Content';
import { PromovawebCTA } from '@/components/PromovawebCTA';
---

<Layout 
	title="PM2 no SetupVibe: Gestão Profissional de Processos e Bots"
	description="Mantenha suas aplicações e bots de IA rodando 24/7 com PM2 e monitoramento nativo no SetupVibe. Garanta estabilidade total para seus serviços. Veja como usar!"
>
	<PageHeader 
		client:load
		title="Domine o" 
		gradientTitle="PM2"
		subtitle="Mantenha seus bots, APIs e scripts de IA rodando silenciosamente com auto-restart e monitoramento em tempo real. Estabilidade total para o seu ecossistema."
		badge={{ icon: "⚡", text: "Process Manager" }}
	/>

	<Pm2Content client:load />
    <PromovawebCTA client:load />
</Layout>
