---
import Layout from '../layouts/main.astro';
import { PageHeader } from '@/components/PageHeader';
import { ComponentTabs } from '@/components/ComponentTabs';
import { PromovawebCTA } from '@/components/PromovawebCTA';
---

<Layout title="Componentes - SetupVibe">
	<PageHeader 
		client:load
		title="Component" 
		gradientTitle="Library"
		subtitle="Uma coleção de componentes bonitos, acessíveis e reutilizáveis construídos com React, Tailwind CSS e Radix UI"
		badge={{ icon: "🎨", text: "UI Showcase" }}
	/>

	<section class="pb-20 md:pb-32">
		<div class="container mx-auto px-4">
			<div class="max-w-6xl mx-auto">
				<ComponentTabs client:load />
			</div>
		</div>
	</section>
    <PromovawebCTA client:load />
</Layout>
