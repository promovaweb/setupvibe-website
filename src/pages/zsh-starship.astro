---
import Layout from '../layouts/main.astro';
import { PageHeader } from '@/components/PageHeader';
import { ZshStarshipContent } from '@/components/ZshStarshipContent';
import { PromovawebCTA } from '@/components/PromovawebCTA';
---

<Layout 
	title="ZSH e Starship no SetupVibe: O Terminal Mais Bonito"
	description="Descubra a configuração de terminal do SetupVibe com ZSH e Starship. Performance bruta e estética incrível para seu dia a dia de coding. Configure seu shell!"
>
	<PageHeader 
		client:load
		title="Experiência de" 
		gradientTitle="Terminal Moderna"
		subtitle="Substituímos o prompt cru por uma interface inteligente, rápida e visualmente incrível. ZSH e Starship trabalhando juntos para o seu workflow."
		badge={{ icon: "", text: "ZSH & Starship" }}
	/>

	<ZshStarshipContent client:load />
    <PromovawebCTA client:load />
</Layout>
