---
import Layout from '../layouts/main.astro';
import { PageHeader } from '@/components/PageHeader';
import { SetupContent } from '@/components/SetupContent';
import { PromovawebCTA } from '@/components/PromovawebCTA';
import { getCollection } from 'astro:content';
import { sortChangelog } from '@/lib/utils';

const changelogEntries = await getCollection('changelog');
const sortedEntries = sortChangelog(changelogEntries);
const latestVersion = sortedEntries[0]?.data.version || '0.0.0';
---

<Layout 
	title="Como Instalar o SetupVibe: Setup do Terminal em 1 Minuto"
	description="Transforme sua máquina no ambiente perfeito de Vibe Coding com um único comando. Suporte para Mac, Linux e WSL2. Comece agora sua jornada gratuita no terminal!"
>
  <script type="application/ld+json" is:inline slot="head">
    {
      "@context": "https://schema.org",
      "@type": "HowTo",
      "name": "Como instalar o SetupVibe",
      "description": "Siga estes passos simples para instalar o SetupVibe no seu Mac ou Linux.",
      "step": [
        {
          "@type": "HowToStep",
          "name": "Abra seu Terminal",
          "text": "Inicie o aplicativo de terminal da sua preferência (iTerm2, Warp ou o nativo)."
        },
        {
          "@type": "HowToStep",
          "name": "Execute o comando de instalação",
          "text": "Copie e cole o comando: curl -sSL desktop.setupvibe.dev | bash para Desktop ou curl -sSL server.setupvibe.dev | bash para Servidores."
        },
        {
          "@type": "HowToStep",
          "name": "Aguarde a conclusão",
          "text": "O script irá baixar e configurar todas as ferramentas automaticamente. Isso leva apenas 5 minutos."
        }
      ]
    }
  </script>

	<PageHeader 
		client:load
		title="Desbloqueie seu novo" 
		gradientTitle="superpoder agora"
		subtitle="Copie, cole e entre em ação. Transformamos seu terminal comum em um assistente de elite em menos de 5 minutos, sem que você precise abrir um manual."
		badge={{ icon: "⚡", text: `Setup Instantâneo v${latestVersion}` }}
	/>

	<SetupContent client:load />
    <PromovawebCTA client:load />
</Layout>
