---
import Layout from '../layouts/main.astro';
import { PageHeader } from '@/components/PageHeader';
import { SetupContent } from '@/components/SetupContent';
import { PromovawebCTA } from '@/components/PromovawebCTA';
---

<Layout 
	title="Como Instalar o SetupVibe - Instalação em 1 Comando"
	description="Transforme seu Mac ou servidor Linux na máquina perfeita de Vibe Coding com apenas um comando. Suporte para desktop e servidores headless."
>
  <script type="application/ld+json" is:inline slot="head">
    {
      "@context": "https://schema.org",
      "@type": "HowTo",
      "name": "Como instalar o SetupVibe",
      "description": "Siga estes passos simples para instalar o SetupVibe no seu Mac ou Linux.",
      "step": [
        {
          "@type": "HowToStep",
          "name": "Abra seu Terminal",
          "text": "Inicie o aplicativo de terminal da sua preferência (iTerm2, Warp ou o nativo)."
        },
        {
          "@type": "HowToStep",
          "name": "Execute o comando de instalação",
          "text": "Copie e cole o comando: curl -sSL desktop.setupvibe.dev | bash para Desktop ou curl -sSL server.setupvibe.dev | bash para Servidores."
        },
        {
          "@type": "HowToStep",
          "name": "Aguarde a conclusão",
          "text": "O script irá baixar e configurar todas as ferramentas automaticamente. Isso leva de 5 a 10 minutos."
        }
      ]
    }
  </script>

	<PageHeader 
		client:load
		title="Sua máquina pronta para" 
		gradientTitle="Vibe Coding em minutos"
		subtitle="Um comando cirúrgico. Zero configuração manual. Tudo o que você precisa para criar com IA, do terminal ao deploy."
		badge={{ icon: "🚀", text: "Versão 0.38.0 Disponível" }}
	/>

	<SetupContent client:load />
    <PromovawebCTA client:load />
</Layout>
