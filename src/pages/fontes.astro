---
import Layout from '../layouts/main.astro';
import { PageHeader } from '@/components/PageHeader';
import { FontConfigContent } from '@/components/FontConfigContent';
import { PromovawebCTA } from '@/components/PromovawebCTA';
---

<Layout 
	title="Configurar Nerd Fonts no SetupVibe: Guia Passo a Passo"
	description="Aprenda a instalar e configurar Nerd Fonts no Windows, Mac e Linux para habilitar ícones e ligaduras no terminal do SetupVibe. Deixe seu shell profissional!"
>
	<PageHeader 
		client:load
		title="Configuração de" 
		gradientTitle="Tipografia"
		subtitle="Habilite ícones, glifos e ligaduras de programação no seu terminal. Siga nosso guia passo a passo para Windows, Mac e Linux."
		badge={{ icon: "🔡", text: "Nerd Fonts Guide" }}
	/>

	<FontConfigContent client:only="react" />
    <PromovawebCTA client:load />
</Layout>
