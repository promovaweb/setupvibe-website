---
import Layout from '../layouts/main.astro';
import { PageHeader } from '@/components/PageHeader';
import { PortainerContent } from '@/components/PortainerContent';
import { PromovawebCTA } from '@/components/PromovawebCTA';
---

<Layout 
	title="Portainer no SetupVibe: Gestão Visual de Docker e Logs"
	description="Gerencie seus containers Docker com uma interface intuitiva e visual através do Portainer no SetupVibe. Monitore logs e console sem complicações. Teste agora!"
>
	<PageHeader 
		client:load
		title="Gestão visual de containers" 
		gradientTitle="sem complicações"
		subtitle="Pare de brigar com comandos docker ps extensos. Visualize, monitore logs e controle todo o seu ecossistema em uma interface intuitiva e profissional."
		badge={{ icon: "⛴️", text: "Visibilidade" }}
	/>

	<PortainerContent client:load />
    <PromovawebCTA client:load />
</Layout>
