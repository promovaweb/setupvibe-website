---
import Layout from '../layouts/main.astro';
import { PageHeader } from '@/components/PageHeader';
import { PortainerContent } from '@/components/PortainerContent';
import { PromovawebCTA } from '@/components/PromovawebCTA';
---

<Layout 
	title="Portainer: Gestão Visual de Docker - SetupVibe"
	description="Gerencie seus containers Docker de forma visual com Portainer. Interface intuitiva, monitoramento de logs e console interativo integrados ao SetupVibe."
>
	<PageHeader 
		client:load
		title="Domine seu" 
		gradientTitle="Docker"
		subtitle="Visualize e controle todo o seu ecossistema de containers sem precisar decorar comandos complexos. Portainer é a interface definitiva para o desenvolvedor moderno."
		badge={{ icon: "🐳", text: "Portainer CE" }}
	/>

	<PortainerContent client:load />
    <PromovawebCTA client:load />
</Layout>
