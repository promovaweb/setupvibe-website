---
import '../styles/global.css';
import { Header } from '@/components/Header';
import { Footer } from '@/components/Footer';
import { PageProgressBar } from '@/components/PageProgressBar';
import { CommandPalette } from '@/components/CommandPalette';
import { CookieConsent } from '@/components/CookieConsent';
import SocialFloating from '@/components/SocialFloating.astro';
import { SEO } from 'astro-seo';
import { siteConfig } from '@/site.config';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
}

const { 
  title = "SetupVibe - Vibe Coding Environment in 1-Click",
  description = "SetupVibe prepara sua máquina com um clique para que o Claude, Copilot e Gemini façam a mágica acontecer. Ambiente dev completo, rápido e sem complicações.",
  image: customImage,
  canonical
} = Astro.props;

// Determine canonical URL if not provided
const canonicalURL = canonical 
  ? new URL(canonical, Astro.site || Astro.url) 
  : new URL(Astro.url.pathname, Astro.site || Astro.url);

// Calculate OG Image URL
let path = Astro.url.pathname.replace(/^\/|\/$/g, '');
const ogRoute = path === '' ? 'index.png' : `${path}.png`;
const generatedOgImage = new URL(`/og/${ogRoute}`, Astro.url).toString();
const finalOgImage = customImage ? new URL(customImage, Astro.url).toString() : generatedOgImage;
---

<html lang="pt-BR">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">
    <link rel="mask-icon" href="/logo.png" color="#5bbad5">
    <meta name="msapplication-TileColor" content="#da532c">
    <meta name="theme-color" content="#ffffff">
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="alternate" type="text/plain" title="LLM Context Index" href="/llms.txt" />
    <link rel="alternate" type="text/plain" title="LLM Summary" href="/llms-small.txt" />
    <link rel="alternate" type="text/plain" title="Full Content Markdown" href="/llms-full.txt" />
    
    <!-- Advanced SEO & GEO Tags -->
    <meta name="geo.region" content={`${siteConfig.company.address.country}-${siteConfig.company.address.region}`} />
    <meta name="geo.placename" content={siteConfig.company.address.city} />
    <meta name="geo.position" content="-23.5505;-46.6333" />
    <meta name="ICBM" content="-23.5505, -46.6333" />
    <meta name="author" content={siteConfig.company.name} />
    <meta name="publisher" content={siteConfig.company.name} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />

    <!-- Structured Data (JSON-LD) -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "SetupVibe",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "MacOS, Linux, Windows",
      "description": "Ambiente de desenvolvimento 1-click para Vibe Coding com IA.",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": 5,
        "ratingCount": 128,
        "bestRating": 5,
        "worstRating": 1
      },
      "url": "https://setupvibe.dev",
      "image": "https://setupvibe.dev/logo.png",
      "screenshot": "https://setupvibe.dev/logo.png",
      "author": {
        "@type": "Person",
        "name": siteConfig.company.founder
      },
      "publisher": {
        "@type": "Organization",
        "name": siteConfig.company.name,
        "url": siteConfig.company.url,
        "logo": {
          "@type": "ImageObject",
          "url": "https://promovaweb.com/logo.png"
        }
      }
    })}>
    </script>
    
    <!-- Google Tag Manager -->
    <script is:inline define:vars={{ gtmId: siteConfig.gtmId }}>
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer',gtmId);
    </script>
    <script is:inline>
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer','GTM-TNVP8BX8');
    </script>
    <!-- End Google Tag Manager -->

    <!-- Google tag (gtag.js) -->
    <script async is:inline src="https://www.googletagmanager.com/gtag/js?id=G-TGQZSWGYQE"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-TGQZSWGYQE');
    </script>

    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      })();
    
      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    </script>
    
    <slot name="head" />

		<SEO
      title={title}
      description={description}
      canonical={canonicalURL.toString()}
      openGraph={{
        basic: {
          title: title,
          type: "website",
          image: finalOgImage,
          url: canonicalURL.toString(),
        },
        image: {
          alt: title,
        }
      }}
      twitter={{
        creator: "@setupvibe",
        card: "summary_large_image",
        title: title,
        description: description,
        image: finalOgImage,
      }}
      extend={{
        meta: [
          { name: "theme-color", content: "#ffffff" },
        ]
      }}
    />
	</head>
	<body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src={`https://www.googletagmanager.com/ns.html?id=${siteConfig.gtmId}`}
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-TNVP8BX8"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->

    <PageProgressBar client:load />
		<Header client:load />
		<main>
			<slot />
		</main>
		<Footer client:load />
		<CommandPalette client:load />
		<CookieConsent client:load />
		<SocialFloating />
	</body>
</html>
